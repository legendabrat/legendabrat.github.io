<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1920">
<title>LEGENDABRAT Overlay</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

/* OBS: прозрачный фон */
html, body {
  width: 1920px;
  height: 1080px;
  background: transparent;
  overflow: hidden;
  font-family: 'Rajdhani', sans-serif;
}

/* ══════════════════════════════════════
   BOTTOM BAR — главная полоска внизу
   ══════════════════════════════════════ */
.bottom-bar {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 110px;
  background: linear-gradient(90deg,
    rgba(4,2,2,0.97) 0%,
    rgba(12,4,4,0.95) 40%,
    rgba(12,4,4,0.95) 60%,
    rgba(4,2,2,0.97) 100%
  );
  border-top: 2px solid rgba(192,57,43,0.7);
  display: flex;
  align-items: center;
  padding: 0 32px;
  gap: 0;
  animation: slideUp 0.8s cubic-bezier(0.22,1,0.36,1) both;
}

/* Top glow line */
.bottom-bar::before {
  content: '';
  position: absolute;
  top: -1px; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(192,57,43,0.9), rgba(255,100,80,0.6), rgba(192,57,43,0.9), transparent);
  animation: linePulse 3s ease-in-out infinite;
}

/* ── NICK BLOCK ── */
.nick-block {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 280px;
  padding-right: 28px;
  border-right: 1px solid rgba(192,57,43,0.3);
}

.nick-tag {
  font-family: 'Rajdhani', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: rgba(192,57,43,0.6);
  margin-bottom: 2px;
}

.nick-name {
  font-family: 'Oswald', sans-serif;
  font-size: 34px;
  font-weight: 700;
  letter-spacing: 3px;
  color: #c0392b;
  text-shadow: 0 0 20px rgba(192,57,43,0.5);
  line-height: 1;
}

/* ── MMR BLOCK ── */
.mmr-block {
  flex: 1;
  padding: 0 28px;
  border-right: 1px solid rgba(192,57,43,0.3);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 7px;
}

.mmr-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.mmr-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: rgba(192,57,43,0.55);
}

.mmr-values {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.mmr-current {
  font-family: 'Oswald', sans-serif;
  font-size: 28px;
  font-weight: 700;
  color: #e8e0d0;
  letter-spacing: 1px;
}

.mmr-arrow {
  font-size: 16px;
  color: rgba(192,57,43,0.5);
}

.mmr-goal {
  font-family: 'Oswald', sans-serif;
  font-size: 20px;
  font-weight: 500;
  color: rgba(192,57,43,0.7);
  letter-spacing: 1px;
}

.mmr-delta {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 2px 8px;
  border-radius: 3px;
  margin-left: 4px;
}
.mmr-delta.pos { color: #00e676; background: rgba(0,230,118,0.1); border: 1px solid rgba(0,230,118,0.25); }
.mmr-delta.neg { color: #ef5350; background: rgba(239,83,80,0.1); border: 1px solid rgba(239,83,80,0.25); }
.mmr-delta.zero { color: rgba(255,255,255,0.3); }

/* Progress bar */
.mmr-bar-wrap {
  position: relative;
  height: 8px;
  background: rgba(255,255,255,0.06);
  border-radius: 4px;
  overflow: hidden;
}

.mmr-bar-fill {
  height: 100%;
  border-radius: 4px;
  background: linear-gradient(90deg, #8b1a10, #c0392b, #e74c3c);
  box-shadow: 0 0 12px rgba(192,57,43,0.6);
  transition: width 1.2s cubic-bezier(0.22,1,0.36,1);
  position: relative;
}

/* Shine on bar */
.mmr-bar-fill::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 50%;
  background: rgba(255,255,255,0.18);
  border-radius: 4px;
}

/* Glow pulse at bar end */
.mmr-bar-tip {
  position: absolute;
  top: 50%;
  transform: translate(50%, -50%);
  width: 12px; height: 12px;
  background: #ff6b55;
  border-radius: 50%;
  box-shadow: 0 0 10px 4px rgba(255,107,85,0.5);
  animation: tipPulse 1.8s ease-in-out infinite;
}

.mmr-bar-pct {
  position: absolute;
  right: 0; top: -18px;
  font-size: 11px; font-weight: 700;
  color: rgba(192,57,43,0.6);
  letter-spacing: 1px;
}

/* ── W/L BLOCK ── */
.wl-block {
  padding: 0 28px;
  border-right: 1px solid rgba(192,57,43,0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  min-width: 200px;
}

.wl-label {
  font-size: 11px; font-weight: 700; letter-spacing: 4px;
  text-transform: uppercase; color: rgba(192,57,43,0.55);
}

.wl-scores {
  display: flex;
  align-items: center;
  gap: 10px;
}

.wl-win {
  font-family: 'Oswald', sans-serif;
  font-size: 42px; font-weight: 700; line-height: 1;
  color: #00e676;
  text-shadow: 0 0 16px rgba(0,230,118,0.4);
}

.wl-sep {
  font-family: 'Oswald', sans-serif;
  font-size: 28px; color: rgba(255,255,255,0.2);
}

.wl-loss {
  font-family: 'Oswald', sans-serif;
  font-size: 42px; font-weight: 700; line-height: 1;
  color: #ef5350;
  text-shadow: 0 0 16px rgba(239,83,80,0.4);
}

.wl-dots {
  display: flex;
  gap: 4px;
}

.wl-dot {
  width: 10px; height: 10px;
  border-radius: 2px;
}
.wl-dot.w { background: #00e676; box-shadow: 0 0 6px rgba(0,230,118,0.5); }
.wl-dot.l { background: #ef5350; box-shadow: 0 0 6px rgba(239,83,80,0.5); }
.wl-dot.empty { background: rgba(255,255,255,0.08); }

/* ── STREAK BLOCK ── */
.streak-block {
  padding: 0 28px;
  border-right: 1px solid rgba(192,57,43,0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  min-width: 160px;
}

.streak-label {
  font-size: 11px; font-weight: 700; letter-spacing: 4px;
  text-transform: uppercase; color: rgba(192,57,43,0.55);
}

.streak-value {
  font-family: 'Oswald', sans-serif;
  font-size: 38px; font-weight: 700; line-height: 1;
}
.streak-value.win-streak {
  color: #ffd740;
  text-shadow: 0 0 20px rgba(255,215,64,0.5);
  animation: streakGlow 2s ease-in-out infinite;
}
.streak-value.loss-streak { color: #ef5350; }
.streak-value.none { color: rgba(255,255,255,0.25); font-size: 24px; }

.streak-text {
  font-size: 11px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase;
}
.streak-text.win-streak { color: rgba(255,215,64,0.6); }
.streak-text.loss-streak { color: rgba(239,83,80,0.6); }
.streak-text.none { color: rgba(255,255,255,0.2); }

/* ── HERO BLOCK ── */
.hero-block {
  padding: 0 0 0 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  min-width: 150px;
}

.hero-label {
  font-size: 11px; font-weight: 700; letter-spacing: 4px;
  text-transform: uppercase; color: rgba(192,57,43,0.55);
}

.hero-icon {
  width: 54px; height: 54px;
  border-radius: 6px;
  border: 1px solid rgba(192,57,43,0.35);
  background: rgba(192,57,43,0.08);
  display: flex; align-items: center; justify-content: center;
  font-size: 28px;
  position: relative;
  overflow: hidden;
}
.hero-icon::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.06), transparent);
}

.hero-name {
  font-family: 'Oswald', sans-serif;
  font-size: 13px; font-weight: 600; letter-spacing: 1px;
  color: rgba(255,255,255,0.6);
  text-transform: uppercase;
}

/* ══════════════════════════════════════
   TOP RIGHT — Alert area
   ══════════════════════════════════════ */
.alert-area {
  position: absolute;
  top: 30px; right: 30px;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10px;
}

.alert-box {
  background: linear-gradient(135deg, rgba(8,3,3,0.95), rgba(15,5,5,0.95));
  border: 1px solid rgba(192,57,43,0.5);
  border-radius: 6px;
  padding: 12px 18px;
  display: flex;
  align-items: center;
  gap: 10px;
  animation: alertIn 0.5s cubic-bezier(0.22,1,0.36,1) both, alertOut 0.4s ease 4.5s forwards;
  box-shadow: 0 4px 24px rgba(0,0,0,0.6), 0 0 30px rgba(192,57,43,0.1);
}

.alert-box::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(192,57,43,0.8), transparent);
}

.alert-icon { font-size: 22px; }

.alert-text {
  font-family: 'Oswald', sans-serif;
  font-size: 18px; font-weight: 600;
  letter-spacing: 2px; text-transform: uppercase;
}

.alert-text.follow { color: #c0392b; }
.alert-text.winstreak { color: #ffd740; }
.alert-text.mmr-up { color: #00e676; }

/* ══════════════════════════════════════
   TOP LEFT — live indicator
   ══════════════════════════════════════ */
.live-badge {
  position: absolute;
  top: 28px; left: 28px;
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(4,2,2,0.85);
  border: 1px solid rgba(192,57,43,0.4);
  border-radius: 4px;
  padding: 7px 14px;
  animation: slideDown 0.8s 0.3s cubic-bezier(0.22,1,0.36,1) both;
}

.live-dot {
  width: 9px; height: 9px;
  background: #c0392b;
  border-radius: 50%;
  box-shadow: 0 0 8px rgba(192,57,43,0.8);
  animation: livePulse 1.5s ease-in-out infinite;
}

.live-text {
  font-family: 'Oswald', sans-serif;
  font-size: 16px; font-weight: 600;
  letter-spacing: 4px; color: #c0392b;
}

/* ══════════════════════════════════════
   ANIMATIONS
   ══════════════════════════════════════ */
@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}

@keyframes slideDown {
  from { transform: translateY(-20px); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

@keyframes linePulse {
  0%, 100% { opacity: 0.7; }
  50%       { opacity: 1; }
}

@keyframes tipPulse {
  0%, 100% { box-shadow: 0 0 10px 4px rgba(255,107,85,0.4); }
  50%       { box-shadow: 0 0 18px 8px rgba(255,107,85,0.7); }
}

@keyframes streakGlow {
  0%, 100% { text-shadow: 0 0 20px rgba(255,215,64,0.4); }
  50%       { text-shadow: 0 0 40px rgba(255,215,64,0.8), 0 0 80px rgba(255,215,64,0.3); }
}

@keyframes livePulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(192,57,43,0.8); }
  50%       { opacity: 0.5; box-shadow: 0 0 4px rgba(192,57,43,0.3); }
}

@keyframes alertIn {
  from { transform: translateX(40px); opacity: 0; }
  to   { transform: translateX(0);    opacity: 1; }
}

@keyframes alertOut {
  from { transform: translateX(0);    opacity: 1; }
  to   { transform: translateX(60px); opacity: 0; }
}

@keyframes barFill {
  from { width: 0%; }
}
</style>
</head>
<body>

<!-- LIVE badge top-left -->
<div class="live-badge">
  <div class="live-dot"></div>
  <div class="live-text">LIVE</div>
</div>

<!-- Alert demo top-right -->
<div class="alert-area" id="alertArea"></div>

<!-- BOTTOM BAR -->
<div class="bottom-bar">

  <!-- Nick -->
  <div class="nick-block">
    <div class="nick-tag">Dota 2 · RU</div>
    <div class="nick-name" id="nickName">LEGENDABRAT</div>
  </div>

  <!-- MMR Progress -->
  <div class="mmr-block">
    <div class="mmr-header">
      <span class="mmr-label">MMR ПРОГРЕСС</span>
      <div class="mmr-values">
        <span class="mmr-current" id="mmrCurrent">3840</span>
        <span class="mmr-arrow">→</span>
        <span class="mmr-goal" id="mmrGoal">4000</span>
        <span class="mmr-delta pos" id="mmrDelta">+30</span>
      </div>
    </div>
    <div class="mmr-bar-wrap">
      <div class="mmr-bar-pct" id="mmrPct">92%</div>
      <div class="mmr-bar-fill" id="mmrBar" style="width: 0%">
        <div class="mmr-bar-tip" id="barTip" style="right: -6px"></div>
      </div>
    </div>
  </div>

  <!-- W/L -->
  <div class="wl-block">
    <span class="wl-label">Сессия</span>
    <div class="wl-scores">
      <span class="wl-win" id="wins">4</span>
      <span class="wl-sep">/</span>
      <span class="wl-loss" id="losses">2</span>
    </div>
    <div class="wl-dots" id="wlDots"></div>
  </div>

  <!-- Streak -->
  <div class="streak-block">
    <span class="streak-label">Стрик</span>
    <div class="streak-value win-streak" id="streakVal">3🔥</div>
    <div class="streak-text win-streak" id="streakTxt">WIN STREAK</div>
  </div>

  <!-- Hero -->
  <div class="hero-block">
    <span class="hero-label">Герой</span>
    <div class="hero-icon" id="heroIcon">⚔️</div>
    <div class="hero-name" id="heroName">Invoker</div>
  </div>

</div>

<script>
// ── Читаем параметры из URL ──
const p = new URLSearchParams(location.search);

const mmrCurrent = parseInt(p.get('mmr')    || 3840);
const mmrGoal    = parseInt(p.get('goal')   || 4000);
const mmrStart   = parseInt(p.get('start')  || 3000);
const wins       = parseInt(p.get('wins')   || 4);
const losses     = parseInt(p.get('losses') || 2);
const streak     = parseInt(p.get('streak') || 3);  // + = win, - = loss, 0 = none
const hero       = p.get('hero')  || 'Invoker';
const heroEmoji  = p.get('emoji') || '⚔️';
const delta      = parseInt(p.get('delta')  || 30); // +/- MMR за сессию

// ── Apply values ──
document.getElementById('mmrCurrent').textContent = mmrCurrent;
document.getElementById('mmrGoal').textContent    = mmrGoal;
document.getElementById('heroName').textContent   = hero;
document.getElementById('heroIcon').textContent   = heroEmoji;
document.getElementById('wins').textContent       = wins;
document.getElementById('losses').textContent     = losses;

// Delta
const deltaEl = document.getElementById('mmrDelta');
if (delta > 0) {
  deltaEl.textContent = '+' + delta;
  deltaEl.className = 'mmr-delta pos';
} else if (delta < 0) {
  deltaEl.textContent = delta;
  deltaEl.className = 'mmr-delta neg';
} else {
  deltaEl.textContent = '±0';
  deltaEl.className = 'mmr-delta zero';
}

// ── MMR Bar ──
const range = mmrGoal - mmrStart;
const progress = Math.max(0, Math.min(100, ((mmrCurrent - mmrStart) / range) * 100));
const pct = Math.round(progress);
document.getElementById('mmrPct').textContent = pct + '%';

// Animate bar on load
setTimeout(() => {
  const bar = document.getElementById('mmrBar');
  bar.style.width = pct + '%';
}, 300);

// ── W/L Dots ──
const dotsEl = document.getElementById('wlDots');
const history = p.get('history') || '';
// e.g. history=WWLWLW
const results = history.toUpperCase().split('').filter(c => c==='W' || c==='L');
// Build last 8 dots
const maxDots = 8;
const filled = results.slice(-maxDots);
const empty  = maxDots - filled.length;
for (let i = 0; i < empty; i++) {
  const d = document.createElement('div');
  d.className = 'wl-dot empty';
  dotsEl.appendChild(d);
}
filled.forEach(r => {
  const d = document.createElement('div');
  d.className = 'wl-dot ' + (r === 'W' ? 'w' : 'l');
  dotsEl.appendChild(d);
});

// ── Streak ──
const strEl  = document.getElementById('streakVal');
const strTxt = document.getElementById('streakTxt');
if (streak > 1) {
  strEl.textContent = streak + '🔥';
  strEl.className   = 'streak-value win-streak';
  strTxt.textContent = 'WIN STREAK';
  strTxt.className  = 'streak-text win-streak';
} else if (streak < -1) {
  strEl.textContent = Math.abs(streak) + '💀';
  strEl.className   = 'streak-value loss-streak';
  strTxt.textContent = 'LOSS STREAK';
  strTxt.className  = 'streak-text loss-streak';
} else {
  strEl.textContent = '—';
  strEl.className   = 'streak-value none';
  strTxt.textContent = 'НЕТ СТРИКА';
  strTxt.className  = 'streak-text none';
}

// ── Demo Alerts ──
const alerts = [
  { icon: '💜', text: 'НОВЫЙ ФОЛЛОВЕР!', cls: 'follow', delay: 2000 },
  { icon: '🔥', text: '3 WIN STREAK!',   cls: 'winstreak', delay: 8000 },
  { icon: '📈', text: 'MMR +30!',         cls: 'mmr-up', delay: 14000 },
];

function showAlert(icon, text, cls) {
  const area = document.getElementById('alertArea');
  const box = document.createElement('div');
  box.className = 'alert-box';
  box.innerHTML = `<span class="alert-icon">${icon}</span><span class="alert-text ${cls}">${text}</span>`;
  area.prepend(box);
  setTimeout(() => box.remove(), 5200);
}

alerts.forEach(a => {
  setTimeout(() => showAlert(a.icon, a.text, a.cls), a.delay);
  // Loop demo alerts
  setInterval(() => showAlert(a.icon, a.text, a.cls), 20000);
});
</script>
</body>
</html>
